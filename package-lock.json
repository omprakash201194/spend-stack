{
  "name": "spendstack",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "spendstack",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=22.0.0",
        "npm": ">=10.0.0"
      }
    },
    "apps/desktop": {
      "name": "@spendstack/desktop",
      "version": "0.1.0"
    },
    "node_modules/@spendstack/database": {
      "resolved": "packages/database",
      "link": true
    },
    "node_modules/@spendstack/desktop": {
      "resolved": "apps/desktop",
      "link": true
    },
    "node_modules/@spendstack/parser-engine": {
      "resolved": "packages/parser-engine",
      "link": true
    },
    "node_modules/@spendstack/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@spendstack/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "packages/database": {
      "name": "@spendstack/database",
      "version": "0.1.0"
    },
    "packages/parser-engine": {
      "name": "@spendstack/parser-engine",
      "version": "0.1.0"
    },
    "packages/shared": {
      "name": "@spendstack/shared",
      "version": "0.1.0"
    },
    "packages/ui": {
      "name": "@spendstack/ui",
      "version": "0.1.0"
    }
  }
}
