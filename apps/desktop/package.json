{
  "name": "@spendstack/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for SpendStack.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json --noEmit && vite build",
