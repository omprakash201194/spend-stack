    "test:e2e": "echo \"TODO: add Playwright E2E\"",
    "clean": "rm -rf dist dist-electron"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "35.7.5",
    "vite": "7.3.1",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-electron-renderer": "0.14.6"
  },
  "dependencies": {
    "@spendstack/infrastructure": "*",
    "@spendstack/parser-engine": "*",
    "@spendstack/shared": "*",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
